<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <?include $(var.GeneratedFilesWxi) ?>

  <Package
    Name="DiskCompare"
    Manufacturer="DiskCompare"
    Version="$(var.ProductVersion)"
    UpgradeCode="ed1a78d8-0568-4a8a-b7f3-1aef599f8129"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of DiskCompare is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Icon Id="DiskCompareIcon" SourceFile="$(var.IconPath)" />
    <Property Id="ARPPRODUCTICON" Value="DiskCompareIcon" />
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <Feature Id="MainFeature" Title="DiskCompare" Level="1">
      <ComponentGroupRef Id="PublishedFiles" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DiskCompare" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="DiskCompare">
        <Component Id="ApplicationShortcut" Guid="0ef2bd21-ac27-4d3d-8f8a-a7e0b91935a2">
          <Shortcut
            Id="DiskCompareStartMenuShortcut"
            Name="DiskCompare"
            Icon="DiskCompareIcon"
            Target="[INSTALLFOLDER]DiskCompare.exe"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\DiskCompare" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>
  </Package>
</Wix>
